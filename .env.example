# Supabase credentials.
# Copy this file to ".env" and paste your real values, then restart `npm run dev`.
# Find these in Supabase: Project Settings → API.
#
# Safe to expose in a front-end app (the anon key is public by design;
# your data is protected by Row Level Security from supabase-schema.sql).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
